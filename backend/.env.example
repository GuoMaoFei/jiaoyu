# === Environment ===
DEBUG=false
ENVIRONMENT=development

# === Database ===
DATABASE_URL=sqlite+aiosqlite:///./treeedu.db

# === LLM API Keys ===
OPENAI_API_KEY=
GEMINI_API_KEY=
DEEPSEEK_API_KEY=
ALIYUN_API_KEY=
OPENROUTER_API_KEY=
MINIMAX_API_KEY=

# === Kimi VLM OCR (Volcano Engine) ===
KIMI_API_KEY=f4457a91-7260-49df-b346-9cf771c6e58d
KIMI_OCR_MODEL=kimi-k2.5

# === PageIndex ===
PAGEINDEX_API_KEY=

# === Multimodal LLM Routing Strategy ===
LLM_FAST_MODEL=openrouter
LLM_MEDIUM_MODEL=openrouter
LLM_HEAVY_MODEL=openrouter
LLM_VISION_MODEL=openrouter

# === JWT Settings ===
JWT_SECRET_KEY=your_secure_secret_key_at_least_32_characters
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=120

# === CORS Settings ===
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
