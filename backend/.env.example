# === Environment ===
DEBUG=false
ENVIRONMENT=development

# === Database ===
DATABASE_URL=sqlite+aiosqlite:///./treeedu.db

# === LLM API Keys ===
OPENAI_API_KEY=
GEMINI_API_KEY=
DEEPSEEK_API_KEY=
ALIYUN_API_KEY=

# === PageIndex ===
PAGEINDEX_API_KEY=

# === Multimodal LLM Routing Strategy ===
LLM_FAST_MODEL=aliyun
LLM_HEAVY_MODEL=aliyun
LLM_VISION_MODEL=aliyun

# === JWT Settings ===
JWT_SECRET_KEY=your_secure_secret_key_at_least_32_characters
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=120

# === CORS Settings ===
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
