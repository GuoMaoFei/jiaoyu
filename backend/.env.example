# ========================================
# TreeEdu Agent Backend Environment Variables
# ========================================

# App
PROJECT_NAME="TreeEdu Agent Backend"
VERSION="1.0.0"

# Database
# Use SQLite for PoC, swap to Postgres later
DATABASE_URL="sqlite+aiosqlite:///./treeedu.db"

# LLM Providers API Keys
OPENAI_API_KEY="sk-..."
GEMINI_API_KEY="AIza..."
DEEPSEEK_API_KEY="sk-..."

# PageIndex API Key
PAGEINDEX_API_KEY="pi-..."

# Multimodal LLM Routing Strategy
# Options: openai, gemini, deepseek
LLM_FAST_MODEL="openai"
LLM_HEAVY_MODEL="openai"
LLM_VISION_MODEL="openai"
